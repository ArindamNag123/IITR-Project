# Copy this file to .env and fill in your values.
# The app runs without any API key — LLM routing falls back to keyword rules.

# --- LLM (optional but recommended for production) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini    # or gpt-4o, gpt-3.5-turbo

# --- RAG vector store (future) ---
# PINECONE_API_KEY=...
# PINECONE_ENV=us-east-1-aws

# --- Translation API alternative (future) ---
# GOOGLE_TRANSLATE_KEY=...
